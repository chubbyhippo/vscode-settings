{
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "chat.commandCenter.enabled": false,
  "dance.defaultMode": "normal",
  // , / . open this menu (inner / bounds of thing). Keys follow meow's
  // meow-char-thing-table instead of Dance's Kakoune letters:
  //   r round  s square  c curly  g string  p paragraph  l line  b buffer
  //   e symbol  . sentence  (q/Q quotes, a angles, i indent, n number,
  //   u argument, space whitespace keep Dance's extras)
  // d/defun has no VS Code object - use ,c / .c for the enclosing braces.
  // Only the "object" menu is overridden; VS Code merges object settings by
  // top-level key, so Dance's goto/view menus stay intact.
  "dance.menus": {
    "object": {
      "title": "Select object... (meow things)",
      "items": {
        "r()": {
          "command": "dance.seek.object",
          "args": [{ "input": "\\((?#inner)\\)" }],
          "text": "round · ( )"
        },
        "s[]": {
          "command": "dance.seek.object",
          "args": [{ "input": "\\[(?#inner)\\]" }],
          "text": "square · [ ]"
        },
        "c{}": {
          "command": "dance.seek.object",
          "args": [{ "input": "\\{(?#inner)\\}" }],
          "text": "curly · { }"
        },
        "g\"": {
          "command": "dance.seek.object",
          "args": [
            { "input": "(?#noescape)\"(?#inner)(?#noescape)\"" }
          ],
          "text": "string · \" \""
        },
        "q'": {
          "command": "dance.seek.object",
          "args": [
            { "input": "(?#noescape)'(?#inner)(?#noescape)'" }
          ],
          "text": "single quote string"
        },
        "Q`": {
          "command": "dance.seek.object",
          "args": [
            { "input": "(?#noescape)`(?#inner)(?#noescape)`" }
          ],
          "text": "grave quote string"
        },
        "a<>": {
          "command": "dance.seek.object",
          "args": [{ "input": "<(?#inner)>" }],
          "text": "angle block"
        },
        "p": {
          "command": "dance.seek.object",
          "args": [{ "input": "(?#predefined=paragraph)" }],
          "text": "paragraph"
        },
        "l": {
          "command": "dance.seek.object",
          "args": [{ "input": "(?#singleline)[^\\n]+" }],
          "text": "line"
        },
        "b": {
          "command": "dance.seek.object",
          "args": [{ "input": "[\\s\\S]+" }],
          "text": "buffer"
        },
        "e": {
          "command": "dance.seek.object",
          "args": [{ "input": "[\\p{L}_\\d-]+" }],
          "text": "symbol"
        },
        ".": {
          "command": "dance.seek.object",
          "args": [{ "input": "(?#predefined=sentence)" }],
          "text": "sentence"
        },
        "w": {
          "command": "dance.seek.object",
          "args": [{ "input": "[\\p{L}_\\d]+(?<after>[^\\S\\n]+)" }],
          "text": "word"
        },
        "W": {
          "command": "dance.seek.object",
          "args": [{ "input": "[\\S]+(?<after>[^\\S\\n]+)" }],
          "text": "WORD"
        },
        " ": {
          "command": "dance.seek.object",
          "args": [
            { "input": "(?<before>[\\s]+)[^\\S\\n]+(?<after>[\\s]+)" }
          ],
          "text": "whitespaces"
        },
        "i": {
          "command": "dance.seek.object",
          "args": [{ "input": "(?#predefined=indent)" }],
          "text": "indent"
        },
        "n": {
          "command": "dance.seek.object",
          "args": [
            { "input": "(?#singleline)-?[\\d_]+(\\.[0-9]+)?([eE]\\d+)?" }
          ],
          "text": "number"
        },
        "u": {
          "command": "dance.seek.object",
          "args": [{ "input": "(?#predefined=argument)" }],
          "text": "argument"
        },
        "C": {
          "command": "dance.seek.object",
          "text": "custom object desc"
        }
      }
    }
  },
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.lineHeight": 1.2,
  "editor.lineNumbers": "relative",
  "editor.mouseWheelZoom": true,
  "explorer.autoReveal": true,
  "files.autoSave": "afterDelay",
  "git.openRepositoryInParentFolders": "always",
  "http.proxyStrictSSL": false,
  "numberedBookmarks.navigateThroughAllFiles": "replace",
  "telemetry.telemetryLevel": "off",
  "window.commandCenter": false,
  "window.menuBarVisibility": "toggle",
  "workbench.activityBar.iconClickBehavior": "toggle",
  "workbench.activityBar.location": "top",
  "workbench.colorTheme": "GitHub Dark Default",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.tree.renderIndentGuides": "onHover"
}
